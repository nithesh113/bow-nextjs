{
  "name": "bow-nextjs",
  "version": "6.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:win": "node -r ./scripts/node-realpath-patch.cjs ./node_modules/prisma/build/index.js generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prisma:generate": "node -r ./scripts/node-realpath-patch.cjs ./node_modules/prisma/build/index.js generate",
    "prisma:push": "node -r ./scripts/node-realpath-patch.cjs ./node_modules/prisma/build/index.js db push",
    "postinstall": "prisma generate || true"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "nodemailer": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.9",
    "prisma": "^6.19.3",
    "typescript": "5.9.3"
  },
  "overrides": {
    "picomatch": "4.0.4"
  }
}
