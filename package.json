{
  "name": "bow-nextjs",
  "version": "6.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node --require ./scripts/node-realpath-patch.cjs ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prisma:generate": "node --require ./scripts/node-realpath-patch.cjs ./node_modules/prisma/build/index.js generate",
    "prisma:push": "node --require ./scripts/node-realpath-patch.cjs ./node_modules/prisma/build/index.js db push"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.4",
    "sonner": "^2.0.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "@types/react": "18.3.31",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "typescript": "5.9.3"
  }
}
