generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── v7.0.0 — UserRole enum + User.role for admin foundation ──
enum UserRole {
  USER
  ADMIN
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  email               String               @unique
  /// Public, case-insensitive unique handle — login + sharing.
  /// Twitter-style: 3–30 chars, [a-zA-Z0-9_], lowercased on store.
  /// Uniqueness is enforced via a case-insensitive expression index
  /// in the migration (`users_user_id_lower_unique_idx`), not via
  /// `@unique` (Prisma can't express expression indexes natively).
  userId              String?              @map("user_id")
  passwordHash        String               @map("password_hash")
  currency            String?              @default("JPY")
  location            String?              @default("Japan")
  schoolFee           Int                  @default(840000) @map("school_fee")
  emailVerified       DateTime?            @map("email_verified") @db.Timestamptz(6)
  actualTimesEnabled  Boolean              @default(false) @map("actual_times_enabled")
  // Default USER keeps existing rows backward-compatible. New columns
  // with defaults are non-destructive in `db push`, and the migration
  // baseline captures them explicitly.
  role                UserRole             @default(USER)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  expenseCategories   ExpenseCategory[]
  expenses            Expense[]
  templates           UserTemplate[]
  shifts              UserShift[]
  jobs                UserJob[]
  budgetMonthMetas    UserBudgetMonthMeta[]
  budgetGoals         UserBudgetGoal[]
  adminAuditActions   AdminAuditLog[]      @relation("AdminAuditLogActor")
  emailLogs           EmailLog[]
  feedback            UserFeedback[]

  @@map("users")
}

// ── v7.1.0 — User feedback (Plan §26) ─────────────
// Lightweight in-app feedback system that lets users send reviews,
// feature suggestions, and bug reports. Admins triage in
// /admin/feedback. Status is a string so admin workflows can be
// reskinned without schema migrations.
model UserFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String
  rating    Int?
  message   String
  page      String?
  status    String   @default("NEW")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_feedback_user_idx")
  @@index([type], map: "user_feedback_type_idx")
  @@index([status], map: "user_feedback_status_idx")
  @@index([createdAt(sort: Desc)], map: "user_feedback_created_at_desc_idx")
  @@map("user_feedback")
}

// ── v7.0.0 — Admin audit log ──────────────────
model AdminAuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  adminUserId  String   @map("admin_user_id") @db.Uuid
  action       String
  targetType   String?  @map("target_type")
  targetId     String?  @map("target_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  adminUser User @relation("AdminAuditLogActor", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId], map: "admin_audit_log_admin_idx")
  @@index([createdAt(sort: Desc)], map: "admin_audit_log_created_at_desc_idx")
  @@index([action], map: "admin_audit_log_action_idx")
  @@map("admin_audit_log")
}

// ── v7.1.0 — Email log (Plan §32) ─────────────
// Per-row history of every transactional email the app tried to
// send. Written around lib/auth/smtp.ts:sendMail() so the row is
// created whether SMTP successed or failed — rows with status='sent'
// have a providerMessageId; rows with status='failed' have a
// human-readable error string. Used by /admin/emails + future
// alerting. No FK to user — emails may target non-users (account
// creation landing in a Spam folder, etc).
model EmailLog {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String?  @map("user_id") @db.Uuid
  to                String
  type              String
  status            String   // 'sent' | 'failed'
  providerMessageId String?  @map("provider_message_id")
  error             String?
  subject           String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "email_log_created_at_desc_idx")
  @@index([to], map: "email_log_to_idx")
  @@index([status], map: "email_log_status_idx")
  @@index([type], map: "email_log_type_idx")
  @@map("email_log")
  // Optional relation — null for emails to non-users (e.g. bounces
  // for failed account creations where User row never landed).
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model VerificationToken {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  token      String   @unique
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model ExpenseCategory {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  name      String
  icon      String    @default("📌")
  budget    Int       @default(20000)
  parentId  String?   @db.Uuid
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent            ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          ExpenseCategory[] @relation("CategoryHierarchy")
  expenses          Expense[]         @relation("CategoryToExpense")
  subcategoryOf     Expense[]         @relation("SubcategoryToExpense")

  @@index([userId])
  @@index([userId, parentId])
  @@map("expense_categories")
}

model Expense {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  categoryId     String    @map("category_id") @db.Uuid
  subcategoryId  String?   @map("subcategory_id") @db.Uuid
  amount         Float
  date           DateTime  @db.Date
  note           String    @default("")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    ExpenseCategory  @relation("CategoryToExpense", fields: [categoryId], references: [id])
  subcategory ExpenseCategory? @relation("SubcategoryToExpense", fields: [subcategoryId], references: [id])

  @@index([userId, date], map: "expenses_user_date_idx")
  @@index([userId, categoryId], map: "expenses_user_cat_idx")
  @@index([userId, date(sort: Desc)], map: "expenses_user_date_desc_idx")
  @@map("expenses")
}

model UserTemplate {
  /// User-prefixed compound id: `{userId}_tpl{seq}` (e.g. `nithesh_tpl1`).
  /// Generated by `lib/ids.ts:makeUserRowId` at create time; no
  /// database-level default.
  id          String   @id
  userId      String   @db.Uuid
  name        String
  days        Json     // int[]
  jobId       String
  start       String   // "HH:MM"
  end         String   // "HH:MM"
  workDetails String?  // optional free-text per-template note (branches, breaks, etc.)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_templates")
}

model UserShift {
  /// User-prefixed compound id: `{userId}_s{seq}` (e.g. `nithesh_s1`).
  /// Generated by `lib/ids.ts:makeUserRowId` at create time; no
  /// database-level default.
  id          String   @id
  userId      String   @db.Uuid
  date        DateTime @db.Date
  jobId       String
  start       String   // "HH:MM" — scheduled
  end         String   // "HH:MM" — scheduled
  actualLogin  String?  // "HH:MM" — actual clock-in (per-minute pay)
  actualLogout String?  // "HH:MM" — actual clock-out
  actualBreaks Json?    // Break[] serialized
  templateId  String?  @db.Uuid
  source      String   @default("manual") // 'manual' | 'template' | 'apply'
  workDetails String?  // optional free-text note (branches, breaks, etc.)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date], map: "user_shifts_user_date_idx")
  @@map("user_shifts")
}

model UserJob {
  /// User-prefixed compound id: `{userId}_j{seq}` (e.g. `nithesh_j1`).
  /// Generated by `lib/ids.ts:makeUserRowId` at create time; no
  /// database-level default.
  id          String   @id
  userId      String   @db.Uuid
  name        String
  color       String
  rate        Int
  nightRate   Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, sortOrder])
  @@map("user_jobs")
}

model UserBudgetMonthMeta {
  /// Cross-cut unique key per user — one row per `monthKey` (YYYY-MM).
  /// Holds the per-month state that is meaningful only at the month
  /// level: notes / free-form reminders. Categories, expenses, and
  /// goals all live in their own tables.
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  monthKey    String   // "YYYY-MM"
  notes       String   @default("")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
  @@index([userId])
  @@map("user_budget_month_metas")
}

model UserBudgetGoal {
  /// Stable client-facing id (Date.now()-style number). Kept as a synthetic
  /// primary key so cross-month goal re-numbering is never needed when
  /// goals span calendar boundaries.
  id           String   @id
  userId       String   @db.Uuid
  name         String
  deadline     String   // "YYYY-MM-DD"
  target       Int
  percentage   Int      @default(0)
  priority     Int      @default(0)
  createdMonth String   @map("created_month") // "YYYY-MM"
  /// Per-month accumulated allocation, keyed by monthKey ("YYYY-MM").
  /// Optional because a brand-new goal may not have any allocations yet.
  monthlyProgress Json?  @map("monthly_progress")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deadline])
  @@map("user_budget_goals")
}