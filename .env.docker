# Image registry / namespace
IMAGE_NAME=bow-nextjs
IMAGE_TAG=latest

# Local container published port. Visit http://localhost:3000 in your browser
# after `docker compose up`. To reach the app from your phone on the same WiFi,
# use http://<your-laptop-IP>:3000 (find the IP with `ipconfig`).
HOST_PORT=3000
CONTAINER_PORT=3000

# docker compose reads .env automatically, so DATABASE_URL etc. just work.
# Run `cp .env.example .env`, fill it in, then `docker compose up --build`.
